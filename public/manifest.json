{
  "name": "SideQuest — Daily Quests with Friends",
  "short_name": "SideQuest",
  "description": "Compete with friends in daily challenges, trivia games, photo quests, and location sharing. Level up, earn XP, dominate the leaderboard.",
  "start_url": "/dashboard",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui"
  ],
  "background_color": "#0a0a0f",
  "theme_color": "#7C5CFF",
  "orientation": "portrait",
  "lang": "en",
  "dir": "ltr",
  "categories": [
    "games",
    "social",
    "entertainment",
    "lifestyle"
  ],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/narrow.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard with daily quests and XP progress"
    },
    {
      "src": "/screenshots/wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "SideQuest desktop experience"
    }
  ],
  "shortcuts": [
    {
      "name": "Daily Quests",
      "short_name": "Quests",
      "description": "View today's active quests",
      "url": "/quests",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "My Party",
      "short_name": "Party",
      "description": "View your lobbies",
      "url": "/lobbies",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Friend Map",
      "short_name": "Map",
      "description": "See friends on the map",
      "url": "/map",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://zugazuni.vercel.app/manifest.json"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://zugazuni.vercel.app"
    },
    {
      "origin": "https://*.vercel.app"
    }
  ],
  "file_handlers": [
    {
      "action": "/quests",
      "accept": {
        "image/png": [
          ".png"
        ],
        "image/jpeg": [
          ".jpg",
          ".jpeg"
        ],
        "image/webp": [
          ".webp"
        ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+sidequest",
      "url": "/quests?id=%s"
    }
  ],
  "share_target": {
    "action": "/quests",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "photos",
          "accept": [
            "image/png",
            "image/jpeg",
            "image/webp"
          ]
        }
      ]
    }
  },
  "widgets": [
    {
      "name": "SideQuest Daily",
      "description": "See your active quests at a glance",
      "tag": "quest-widget",
      "ms_ac_template": "widget/quest-widget.json",
      "screenshots": [
        {
          "src": "/screenshots/narrow.png",
          "sizes": "390x844",
          "label": "Quest widget preview"
        }
      ],
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "serviceworker": {
    "src": "/sw.js",
    "scope": "/",
    "type": "classic",
    "update_via_cache": "none"
  },
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7"
}